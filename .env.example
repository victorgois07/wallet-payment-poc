# API Configuration
API_PORT=3000
API_HOST=0.0.0.0
API_PREFIX=v1

# CORS
CORS_ORIGINS=http://localhost:8081,http://10.0.2.2:8081

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# Database
DB_TYPE=sqlite
DB_DATABASE=wallet.sqlite

# Logging
LOG_LEVEL=info

# Payment Pipeline
PAYMENT_STRATEGY=parallel
PAYMENT_FAILURE_RATE=0.1
