{
  "name": "wallet-payment-poc",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "api:build": "bun run build:shared && cd apps/api && nest build -p tsconfig.build.json",
    "api:dev": "ts-node -r tsconfig-paths/register --swc apps/api/src/main.ts",
    "api:lint": "biome check apps/api/src",
    "api:start": "ts-node -r tsconfig-paths/register --swc apps/api/src/main.ts",
    "api:test": "vitest run --config apps/api/vitest.config.ts",
    "build:shared": "cd libs/shared && tsc -p tsconfig.json",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "nx run-many -t lint",
    "lint:fix": "biome check --write .",
    "mobile:android": "nx run-android mobile",
    "mobile:ios": "nx run-ios mobile",
    "mobile:lint": "nx lint mobile",
    "mobile:start": "nx start mobile",
    "mobile:test": "nx test mobile",
    "test": "nx run-many -t test",
    "dev:android": "concurrently -n api,mobile -c blue,green \"bun run api:dev\" \"bun run mobile:android\"",
    "dev:ios": "concurrently -n api,mobile -c blue,green \"bun run api:dev\" \"bun run mobile:ios\"",
    "typecheck": "tsc --noEmit -p apps/api && tsc --noEmit -p apps/mobile"
  },
